@model MyFormApp.Models.UserFormModel

@{
    ViewData["Title"] = "Submission Summary";
}

<div class="page-wrapper">
    <div class="summary-container animate-fade-in">
        <!-- Success Header -->
        <div class="success-header">
            <div class="success-icon animate-pop">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                    <path d="m9 11 3 3L22 4"/>
                </svg>
            </div>
            <h1 class="summary-title">Submitted Successfully!</h1>
            <p class="summary-subtitle">Your details have been received. Here's a summary of what you submitted.</p>
        </div>

        <!-- Data Cards -->
        <div class="data-grid">
            <!-- Full Name Card -->
            <div class="data-card animate-slide-up" style="animation-delay: 0.1s;">
                <div class="data-card-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                </div>
                <div class="data-card-content">
                    <span class="data-label">Full Name</span>
                    <span class="data-value" id="summaryName">@Model.FirstName @Model.LastName</span>
                </div>
            </div>

            <!-- Email Card -->
            <div class="data-card animate-slide-up" style="animation-delay: 0.15s;">
                <div class="data-card-icon email-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                </div>
                <div class="data-card-content">
                    <span class="data-label">Email Address</span>
                    <span class="data-value" id="summaryEmail">@Model.Email</span>
                </div>
            </div>

            <!-- Phone Card -->
            <div class="data-card animate-slide-up" style="animation-delay: 0.2s;">
                <div class="data-card-icon phone-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                </div>
                <div class="data-card-content">
                    <span class="data-label">Phone Number</span>
                    <span class="data-value" id="summaryPhone">
                        @(string.IsNullOrEmpty(Model.PhoneNumber) ? "Not provided" : Model.PhoneNumber)
                    </span>
                </div>
            </div>

            <!-- Message Card (Full Width) -->
            <div class="data-card full-width animate-slide-up" style="animation-delay: 0.25s;">
                <div class="data-card-icon message-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                </div>
                <div class="data-card-content">
                    <span class="data-label">Message</span>
                    <span class="data-value message-text" id="summaryMessage">
                        @(string.IsNullOrEmpty(Model.Message) ? "No message provided" : Model.Message)
                    </span>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="summary-actions animate-slide-up" style="animation-delay: 0.3s;">
            <a asp-controller="Form" asp-action="InputForm" class="btn-back" id="btnBackToForm">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
                <span>Submit Another</span>
            </a>
        </div>
    </div>
</div>
